<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Dark shadow (bottom and right) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#555555" />
            <stroke android:width="2dp" android:color="#000000" />
        </shape>
    </item>
    <!-- Light highlight (top and left) -->
    <item android:bottom="4dp" android:right="4dp" android:top="2dp" android:left="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
        </shape>
    </item>
    <!-- Main panel color -->
    <item android:bottom="4dp" android:right="4dp" android:top="6dp" android:left="6dp">
        <shape android:shape="rectangle">
            <solid android:color="#C6C6C6" />
        </shape>
    </item>
</layer-list>
